    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
